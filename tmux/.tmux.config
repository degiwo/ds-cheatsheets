# change prefix
# unbind C-b
# set -g prefix C-Space
# bind C-Space send-prefix

# increate repeat time (in milliseconds)
# # set -g repeat-time 1000

# split pane
bind -N "Split window vertically" C-v split-window -h -c "#{pane_current_path}"
bind -N "Split window horizontally" C-h split-window -v -c "#{pane_current_path}"

# select next pane
bind -r -N "Select the next pane" o select-pane -t :.+
bind -r -N "Select the previous pane" O select-pane -t :.-

# resize pane
bind -r -N "Resize the pane down by 10" Down resize-pane -D 10
bind -r -N "Resize the pane up by 10" Up resize-pane -U 10
bind -r -N "Resize the pane left by 10" Left resize-pane -L 10
bind -r -N "Resize the pane right by 10" Right resize-pane -R 10

# Pane Border
set -g pane-border-status top

# enter copy mode
unbind [
bind Escape copy-mode

# vim copy mode, yank with Enter
set -g mode-keys vi
bind -T copy-mode-vi v send -X begin-selection

# start window index 1
set -g base-index 1

# rename window to dir
set -g automatic-rename on
set -g automatic-rename-format "#{b:pane_current_path}"

# enable mouse support
set -g mouse on
